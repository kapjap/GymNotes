<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- КАРТА -->
    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ГРАДИЕНТ СВЕРХУ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_top_gradient" />

    <!-- ВЕРХНИЙ UI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/buttonBackGyms"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:tint="#9BB8FF" />

        <TextView
            android:id="@+id/textTitleGyms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Карта залов"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />


    </LinearLayout>

    <!-- ПРЕДУПРЕЖДЕНИЕ О ГЕОЛОКАЦИИ -->
    <LinearLayout
        android:id="@+id/locationWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Геолокация выключена"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Включите геолокацию для поиска залов"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>